{
  "name": "xdrop",
  "description": "Open source file transfer app that encrypts files in your browser and keeps plaintext file names, contents, and keys off the server",
  "private": true,
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/xixu-me/xdrop",
  "repository": {
    "type": "git",
    "url": "https://github.com/xixu-me/xdrop.git"
  },
  "bugs": {
    "url": "https://github.com/xixu-me/xdrop/issues"
  },
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "prettier": "^3.6.2"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @xdrop/web",
    "build:web": "npm run build --workspace @xdrop/web",
    "lint:web": "npm run lint --workspace @xdrop/web",
    "format": "npm run format:prettier && node ./scripts/check-go-format.mjs --write",
    "format:check": "npm run format:check:prettier && node ./scripts/check-go-format.mjs",
    "format:prettier": "prettier --write \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,html,yml,yaml}\"",
    "format:check:prettier": "prettier --check \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,html,yml,yaml}\"",
    "test:web": "npm run test --workspace @xdrop/web",
    "test:web:coverage": "npm run test:coverage --workspace @xdrop/web",
    "typecheck:web": "npm run typecheck --workspace @xdrop/web",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  }
}
